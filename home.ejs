<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LMS | Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('partials/nav') %>

        <div class="container">
            <header class="hero">
                <h1>Welcome to Our LMS</h1>
                <p>Your journey to excellence starts here.</p>
            </header>

            <div class="grid">
                <div class="card">
                    <div class="card-image-container">
                        <img src="/images/courses.jpg" alt="Courses" class="card-img">
                    </div>
                    <h2>Online Courses</h2>
                    <p>Study anytime, anywhere.</p>
                    <a href="/dashboard" class="view-btn">View Courses</a>
                </div>

                <div class="card">
                    <div class="card-image-container">
                        <img src="/images/library.jpg" alt="Library" class="card-img">
                    </div>
                    <h2>Digital Library</h2>
                    <p>All notes in one place.</p>
                    <a href="/library" class="view-btn">Open Library</a>
                </div>

                <div class="card">
                    <div class="card-image-container">
                        <img src="/images/admin.png" alt="Admin" class="card-img">
                    </div>
                    <h2>Admin Panel</h2>
                    <p>Upload your own notes.</p>
                    <% if (user && user.role==='admin' ) { %>
                        <a href="/upload" class="upload-btn">Upload Content</a>
                        <% } else { %>
                            <a href="/login" class="upload-btn">Admin Login</a>
                            <% } %>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>
      <script src="/js/script.js"></script>
            
</body>

</html>